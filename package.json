{
  "name": "carbonazo-pro",
  "version": "1.0.0",
  "description": "Sistema POS Asado El Carbonazo",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "pg": "^8.21.0",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.carbonazo.pos",
    "productName": "Asado El Carbonazo PRO",
    "copyright": "Copyright © 2024 Asado El Carbonazo",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "public/icono.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "El Carbonazo POS"
    }
  }
}
